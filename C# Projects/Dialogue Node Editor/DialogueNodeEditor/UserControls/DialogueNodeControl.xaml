<UserControl x:Class="DialogueNodeEditor.UserControls.DialogueNodeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DialogueNodeEditor.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             DataContext="{Binding}">
    
    <UserControl.Resources>
        <!-- Selection border: yellow when IsSelected, grey otherwise -->
        <Style x:Key="NodeBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush"     Value="#555555"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="Background"      Value="#2D2D30"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="BorderBrush"     Value="#FFC832"/>
                    <Setter Property="BorderThickness" Value="2.5"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Bottom-bar icon button base style -->
        <Style x:Key="BottomBarButtonStyle" TargetType="Button">
            <Setter Property="Width"           Value="24"/>
            <Setter Property="Height"          Value="24"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Remove-entry minus button style -->
        <Style x:Key="RemoveEntryButtonStyle" TargetType="Button">
            <Setter Property="Width"           Value="18"/>
            <Setter Property="Height"          Value="18"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Background"      Value="#5A1A1A"/>
            <Setter Property="Foreground"      Value="#FF6B6B"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#7A2222"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        
        <!-- Node body -->
        <Border Margin="12,0" Style="{StaticResource NodeBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="10"/>
                    <!-- Drag handle strip   -->
                    <RowDefinition Height="Auto"/>
                    <!-- Dialogue id         -->
                    <RowDefinition Height="Auto"/>
                    <!-- Owner               -->
                    <RowDefinition Height="4"/>
                    <!-- Separator gap       -->
                    <RowDefinition Height="Auto"/>
                    <!-- Translation entries -->
                    <RowDefinition Height="Auto"/>
                    <!-- Notes area          -->
                    <RowDefinition Height="Auto"/>
                    <!-- Bottom bar          -->
                </Grid.RowDefinitions>

                <!-- Drag handle -->
                <Border x:Name="DragHandle"
                        Grid.Row="0"
                        Background="#007ACC"
                        CornerRadius="6,6,0,0"
                        Cursor="SizeAll"
                        ToolTip="Drag to move"/>

                <!-- Dialogue ID -->
                <Border Grid.Row="1" Background="#005F9E" Padding="8,4,8,2">
                    <TextBox x:Name="DialogueIdTextBox"
                             Text="{Binding DialogueId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent" Foreground="White"
                             FontWeight="Bold" FontSize="12"
                             BorderThickness="0" CaretBrush="White"/>
                </Border>

                <!-- Owner -->
                <Border Grid.Row="2" Background="#004A7C" Padding="8,2,8,4">
                    <TextBox x:Name="DialogueOwnerIdTextBox"
                             Text="{Binding Owner, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent" Foreground="#AADDFF"
                             FontSize="11" BorderThickness="0" CaretBrush="White"/>
                </Border>

                <!-- Translation entries -->
                <ItemsControl x:Name="TranslationsItemsControl"
                              Grid.Row="4"
                              ItemsSource="{Binding Translations}"
                              Margin="6,4,6,0"
                              GotFocus="TranslationsItemsControl_GotFocus"
                              LostFocus="TranslationsItemsControl_LostFocus">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,6">

                                <!-- Key label + remove button -->
                                <Grid Margin="0,0,0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Foreground="#7A9EC0"
                                               FontSize="10"
                                               FontStyle="Italic"
                                               VerticalAlignment="Center"
                                               Margin="2,0">
                                        <Run Text="&#x2014; "/>
                                        <Run Text="{Binding Key, Mode=OneWay}"/>
                                        <Run Text=" &#x2014;"/>
                                    </TextBlock>

                                    <Button Grid.Column="1"
                                            Content="&#x2212;"
                                            Visibility="{Binding RemoveButtonVisibility}"
                                            Tag="{Binding}"
                                            Click="RemoveTranslation_Click"
                                            Style="{StaticResource RemoveEntryButtonStyle}"
                                            ToolTip="Remove this translation"/>
                                </Grid>

                                <!-- Dialogue text area -->
                                <TextBox Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         MinHeight="60" MaxHeight="130"
                                         Background="#1A1A1A" Foreground="#EEEEEE"
                                         BorderBrush="#555555" BorderThickness="1"
                                         Padding="6,5" FontSize="12"
                                         VerticalScrollBarVisibility="Auto"
                                         CaretBrush="White"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Notes area -->
                <Border x:Name="NotesBorder"
                        Grid.Row="5"
                        Visibility="Collapsed"
                        Margin="6,0,6,4">
                    <StackPanel>
                        <TextBlock Text="&#x2014; Notes &#x2014;"
                                   Foreground="#888888" FontSize="10"
                                   FontStyle="Italic" Margin="2,4,2,2"/>
                        <TextBox x:Name="NotesTextBox"
                                 Text="{Binding Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 MinHeight="36" MaxHeight="100"
                                 Background="#1A1A1A" Foreground="#AAAAAA"
                                 BorderBrush="#444444" BorderThickness="1"
                                 Padding="6,4" FontSize="11"
                                 FontStyle="Italic"
                                 VerticalScrollBarVisibility="Auto"
                                 CaretBrush="White"/>
                    </StackPanel>
                </Border>

                <!-- Bottom bar -->
                <Border Grid.Row="6"
                        Background="#1E1E1E"
                        CornerRadius="0,0,6,6"
                        Padding="6,4">
                    <Grid>

                        <!-- Key picker popup -->
                        <Popup x:Name="AddTranslationPopup"
                               PlacementTarget="{Binding ElementName=AddTranslationButton}"
                               Placement="Top"
                               StaysOpen="False"
                               AllowsTransparency="True">
                            <Border Background="#2D2D30"
                                    BorderBrush="#555555"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    Padding="4">
                                <StackPanel x:Name="TranslationKeyPickerPanel" MinWidth="120"/>
                            </Border>
                        </Popup>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center">

                            <!-- Add translation -->
                            <Button x:Name="AddTranslationButton"
                                    Content="&#xFF0B;"
                                    IsEnabled="{Binding CanAddTranslation}"
                                    Click="AddTranslationButton_Click"
                                    Style="{StaticResource BottomBarButtonStyle}"
                                    Background="#1A3028" Foreground="#81C784"
                                    BorderBrush="#2A5040"
                                    Margin="0,0,4,0"
                                    ToolTip="Add translation"/>

                            <!-- Notes toggle -->
                            <Button x:Name="NotesToggleButton"
                                    Content="&#x2261;"
                                    Click="NotesToggleButton_Click"
                                    ToolTip="Toggle notes">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource BottomBarButtonStyle}">
                                        <Setter Property="Background"   Value="#1E1E30"/>
                                        <Setter Property="Foreground"   Value="#8888CC"/>
                                        <Setter Property="BorderBrush"  Value="#333355"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasNotes}" Value="True">
                                                <Setter Property="Foreground"  Value="#FFC832"/>
                                                <Setter Property="Background"  Value="#2E2800"/>
                                                <Setter Property="BorderBrush" Value="#665500"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- InNode connector (left) -->
        <Ellipse x:Name="InConnector"
                 Width="16" Height="16"
                 Fill="#4FC3F7" Stroke="White" StrokeThickness="1.5"
                 HorizontalAlignment="Left" VerticalAlignment="Center"
                 Cursor="Hand" ToolTip="IN — click to complete a connection"/>

        <!-- OutNode connector (right) -->
        <Ellipse x:Name="OutConnector"
                 Width="16" Height="16"
                 Fill="#81C784" Stroke="White" StrokeThickness="1.5"
                 HorizontalAlignment="Right" VerticalAlignment="Center"
                 Cursor="Hand" ToolTip="OUT — click to start a connection"/>
    </Grid>
</UserControl>
