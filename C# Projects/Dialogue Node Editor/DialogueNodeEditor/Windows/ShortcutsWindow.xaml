<Window x:Class="DialogueNodeEditor.Windows.ShortcutsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DialogueNodeEditor.UserControls"
        mc:Ignorable="d"
        Title="Help" Height="450" Width="800"
        MinWidth="380" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#1A1A1A"
        Foreground="#CCCCCC"
        ShowInTaskbar="False"
        KeyDown="Window_KeyDown">
    <Window.Resources>

        <!-- Section header -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="#007ACC"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Margin"       Value="0,14,0,4"/>
        </Style>

        <!-- Key chip -->
        <Style x:Key="KeyChipStyle" TargetType="Border">
            <Setter Property="Background"      Value="#2D2D30"/>
            <Setter Property="BorderBrush"     Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="4"/>
            <Setter Property="Padding"         Value="7,2"/>
            <Setter Property="Margin"          Value="0,0,4,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Key chip text -->
        <Style x:Key="KeyTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#E0E0E0"/>
            <Setter Property="FontFamily"  Value="Consolas, Courier New"/>
            <Setter Property="FontSize"    Value="12"/>
        </Style>

        <!-- Shortcut description -->
        <Style x:Key="DescriptionStyle" TargetType="TextBlock">
            <Setter Property="Foreground"       Value="#AAAAAA"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Separator line -->
        <Style x:Key="SeparatorStyle" TargetType="Rectangle">
            <Setter Property="Height"     Value="1"/>
            <Setter Property="Fill"       Value="#333333"/>
            <Setter Property="Margin"     Value="0,2,0,0"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Shortcut list -->
        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="20,12,20,4">
            <StackPanel>

                <!-- File -->
                <TextBlock Text="File" Style="{StaticResource SectionHeaderStyle}"/>
                <Rectangle Style="{StaticResource SeparatorStyle}"/>

                <local:ShortcutRow Keys="Ctrl + S"       Description="Save (overwrites current file)"/>
                <local:ShortcutRow Keys="Ctrl + Shift + S" Description="Save As (choose new file location)"/>
                <local:ShortcutRow Keys="Ctrl + E"       Description="Exports graph into tree"/>
                <local:ShortcutRow Keys="Ctrl + O"       Description="Open graph file"/>

                <!-- Edit -->
                <TextBlock Text="Edit" Style="{StaticResource SectionHeaderStyle}"/>
                <Rectangle Style="{StaticResource SeparatorStyle}"/>

                <local:ShortcutRow Keys="Ctrl + Z"       Description="Undo"/>
                <local:ShortcutRow Keys="Ctrl + Y"       Description="Redo"/>
                <local:ShortcutRow Keys="Ctrl + Shift + Z" Description="Redo (alternate)"/>
                <local:ShortcutRow Keys="Delete"         Description="Delete selected nodes"/>

                <!-- Nodes -->
                <TextBlock Text="Nodes" Style="{StaticResource SectionHeaderStyle}"/>
                <Rectangle Style="{StaticResource SeparatorStyle}"/>

                <local:ShortcutRow Keys="Right-click canvas" Description="Open context menu (add / delete node)"/>
                <local:ShortcutRow Keys="Drag handle"        Description="Move node"/>
                <local:ShortcutRow Keys="Left-click node"    Description="Select node"/>
                <local:ShortcutRow Keys="Left-click canvas"  Description="Deselect all"/>

                <!-- Connections -->
                <TextBlock Text="Connections" Style="{StaticResource SectionHeaderStyle}"/>
                <Rectangle Style="{StaticResource SeparatorStyle}"/>

                <local:ShortcutRow Keys="Click OUT connector" Description="Begin drawing a connection"/>
                <local:ShortcutRow Keys="Click IN connector"  Description="Complete the connection"/>
                <local:ShortcutRow Keys="Esc"                 Description="Cancel connection in progress"/>
                <local:ShortcutRow Keys="Left-click wire"    Description="Delete connection"/>

                <!-- Canvas -->
                <TextBlock Text="Canvas" Style="{StaticResource SectionHeaderStyle}"/>
                <Rectangle Style="{StaticResource SeparatorStyle}"/>

                <local:ShortcutRow Keys="Middle-click + drag" Description="Pan the canvas"/>
                <local:ShortcutRow Keys="Scroll wheel"        Description="Zoom in / out"/>
                <local:ShortcutRow Keys="Click + drag canvas" Description="Box-select multiple nodes"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Close button -->
        <Border Grid.Row="1"
                Background="#252526"
                BorderBrush="#333333"
                BorderThickness="0,1,0,0"
                Padding="12,8">
            <Button Content="Close"
                    IsDefault="True"
                    HorizontalAlignment="Right"
                    Width="80" Height="28"
                    Background="#007ACC" Foreground="White"
                    BorderThickness="0"
                    FontSize="12"
                    Cursor="Hand"
                    Click="CloseButton_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background"  Value="#007ACC"/>
                        <Setter Property="Foreground"  Value="White"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Cursor"      Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="4"
                                            Padding="8,4">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1C97EA"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#005A9E"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Border>

    </Grid>
</Window>
