<Window x:Class="DialogueNodeEditor.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DialogueNodeEditor"
        xmlns:userControls="clr-namespace:DialogueNodeEditor.UserControls"
        xmlns:vm="clr-namespace:DialogueNodeEditor.ViewModels"
        mc:Ignorable="d"
        Title="{Binding TitleText}"         
        Height="750" Width="1200"
        MinHeight="500" MinWidth="700"
        Background="#1A1A1A"
        KeyDown="Window_KeyDown">

    <Window.InputBindings>
        <KeyBinding Modifiers="Control"         Key="Z"      Command="{Binding History.UndoCommand}"/>
        <KeyBinding Modifiers="Control"         Key="Y"      Command="{Binding History.RedoCommand}"/>
        <KeyBinding Modifiers="Control+Shift"   Key="Z"      Command="{Binding History.RedoCommand}"/>
        <KeyBinding Modifiers="Control"         Key="S"      Command="{Binding SaveCommand}"/>
        <KeyBinding Modifiers="Control+Shift"   Key="S"      Command="{Binding SaveAsCommand}"/>
        <KeyBinding Modifiers="Control"         Key="E"      Command="{Binding ExportCommand}"/>
        <KeyBinding Modifiers="Control"         Key="C"      Command="{Binding CopyCommand}"/>
        <KeyBinding Modifiers="Control"         Key="V"      Command="{Binding PasteCommand}"/>
        <KeyBinding                             Key="Delete" Command="{Binding DeleteSelectedNodesCommand}"/>
        <KeyBinding Modifiers="Control"         Key="O"      Command="{Binding OpenDialogueFileCommand}"/>
        <KeyBinding Modifiers="Control"         Key="A"      Command="{Binding AddNodeCommand}"/>
    </Window.InputBindings>

    <Window.Resources>

        <!-- Toolbar icon button (save, undo, redo) -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="#CCCCCC"/>
            <Setter Property="FontSize"        Value="16"/>
            <Setter Property="Padding"         Value="8,4"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="3">
                            <ContentPresenter x:Name="Cp"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled"   Value="False">
                                <Setter TargetName="Cp" Property="Opacity" Value="0.3"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3C3C3C"/>
                            </Trigger>
                            <Trigger Property="IsPressed"   Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#505050"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Bottom bar button (Reset View) -->
        <Style x:Key="StatusButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="#AAAAAA"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Padding"         Value="10,3"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3C3C3C"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#505050"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Popup Template -->
        <ControlTemplate x:Key="DarkPopupTemplate" TargetType="ContextMenu">
            <Border Background="#252526"
                    BorderBrush="#3C3C3C"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="0,4">
                <StackPanel IsItemsHost="True" ClipToBounds="True"/>
            </Border>
        </ControlTemplate>

        <!-- Menu Item -->
        <Style x:Key="TopLevelMenuItemStyle" TargetType="MenuItem">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Foreground"            Value="#CCCCCC"/>
            <Setter Property="FontSize"              Value="13"/>
            <Setter Property="Padding"               Value="10,6"/>
            <Setter Property="Background"            Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Grid>
                            <!-- Header (the "File" / "Options" / "Help" label) -->
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}"
                                    CornerRadius="3">
                                <ContentPresenter ContentSource="Header"
                                                  TextBlock.Foreground="{TemplateBinding Foreground}"/>
                            </Border>

                            <!-- Dropdown popup containing child items -->
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsSubmenuOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Background="#252526"
                                        BorderBrush="#3C3C3C"
                                        BorderThickness="1"
                                        CornerRadius="0,0,4,4"
                                        Padding="0,4"
                                        MinWidth="160">
                                    <StackPanel IsItemsHost="True" ClipToBounds="True"/>
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted"  Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3C3C3C"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3C3C3C"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Submenu item (New / Open / Save / Exit etc.) -->
        <Style x:Key="SubMenuItemStyle" TargetType="MenuItem">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Foreground"            Value="#CCCCCC"/>
            <Setter Property="FontSize"              Value="12"/>
            <Setter Property="Padding"               Value="14,6"/>
            <Setter Property="Background"            Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <DockPanel>
                                <ContentPresenter ContentSource="Header"
                                                  TextBlock.Foreground="{TemplateBinding Foreground}"
                                                  DockPanel.Dock="Left"/>
                                <TextBlock Text="{TemplateBinding InputGestureText}"
                                           Foreground="#666666"
                                           FontSize="11"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Margin="24,0,0,0"/>
                            </DockPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#094771"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#555555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Separator inside a dark menu  -->
        <Style x:Key="DarkSeparatorStyle" TargetType="Separator">
            <Setter Property="Background"   Value="#3C3C3C"/>
            <Setter Property="Height"       Value="1"/>
            <Setter Property="Margin"       Value="0,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1" Background="#3C3C3C" Margin="0,4"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Context menu style -->
        <Style TargetType="ContextMenu">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="SnapsToDevicePixels"   Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="#252526"
                                BorderBrush="#3C3C3C"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="0,4">
                            <StackPanel IsItemsHost="True" ClipToBounds="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Context menu item style -->
        <Style x:Key="ContextMenuItemStyle" TargetType="MenuItem">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Foreground"            Value="#CCCCCC"/>
            <Setter Property="FontSize"              Value="12"/>
            <Setter Property="Padding"               Value="14,6"/>
            <Setter Property="Background"            Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#094771"/>
                                <Setter Property="Foreground"                 Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#555555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <DockPanel>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top"
                Background="#252526"
                BorderBrush="#3C3C3C" BorderThickness="0,0,0,1"
                Height="36">
            <DockPanel>

                <!-- Menu items (File / Options / Help) -->
                <Menu DockPanel.Dock="Left"
                      Background="Transparent"
                      VerticalAlignment="Center"
                      Margin="4,0">

                    <MenuItem Style="{StaticResource TopLevelMenuItemStyle}" Header="File">
                        <MenuItem Style="{StaticResource SubMenuItemStyle}" Header="New" Click="Menu_New_Click"/>
                        <MenuItem Style="{StaticResource SubMenuItemStyle}" Header="Open…" Click="Menu_Open_Click"
                                   InputGestureText="Ctrl+O"/>
                        <MenuItem Style="{StaticResource SubMenuItemStyle}" Header="Save" Click="Menu_Save_Click"
                                  InputGestureText="Ctrl+S"/>
                        <MenuItem Style="{StaticResource SubMenuItemStyle}" Header="SaveAs" Click="Menu_SaveAs_Click"
                                  InputGestureText="Ctrl+Shift+S"/>
                        <Separator Style="{StaticResource DarkSeparatorStyle}"/>
                        <MenuItem Style="{StaticResource SubMenuItemStyle}" Header="Export" Click="Menu_Export_Click"
                                  InputGestureText="Ctrl+E"/>
                        <Separator Style="{StaticResource DarkSeparatorStyle}"/>
                        <MenuItem Style="{StaticResource SubMenuItemStyle}" Header="Exit" Click="Menu_Exit_Click"/>
                    </MenuItem>

                    <MenuItem Style="{StaticResource TopLevelMenuItemStyle}" Header="Help" Click="Menu_Help_Click"/>
                </Menu>

                <!-- Right-hand icon group -->
                <StackPanel DockPanel.Dock="Left"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="6,0">
                    
                    <Separator Width="1" Background="#3C3C3C" Margin="0,4"/>

                    <!-- Save icon -->
                    <Button Style="{StaticResource IconButtonStyle}"
                            Click="Menu_Save_Click"
                            Margin="4,0,0,0"
                            ToolTip="Save  (Ctrl+S)">
                        <Canvas Width="16" Height="16">
                            <Rectangle Canvas.Left="1"  Canvas.Top="1"
                                       Width="14" Height="14"
                                       RadiusX="1" RadiusY="1"
                                       Fill="#CCCCCC"/>

                            <Rectangle Canvas.Left="4"  Canvas.Top="7"
                                       Width="8" Height="6"
                                       Fill="#252526"/>

                            <Rectangle Canvas.Left="4"  Canvas.Top="1"
                                       Width="7" Height="4"
                                       Fill="#252526"/>

                            <Rectangle Canvas.Left="9"  Canvas.Top="2"
                                       Width="2" Height="2"
                                       Fill="#AAAAAA"/>
                        </Canvas>
                    </Button>

                    <Separator Width="1" Background="#3C3C3C" Margin="6,4"/>

                    <!-- Undo -->
                    <Button Style="{StaticResource IconButtonStyle}"
                            Command="{Binding History.UndoCommand}"
                            ToolTip="Undo  (Ctrl+Z)"
                            Margin="2,0">
                        <TextBlock Text="↩" FontSize="15" Foreground="#CCCCCC"/>
                    </Button>

                    <!-- Redo -->
                    <Button Style="{StaticResource IconButtonStyle}"
                            Command="{Binding History.RedoCommand}"
                            ToolTip="Redo  (Ctrl+Y / Ctrl+Shift+Z)"
                            Margin="2,0">
                        <TextBlock Text="↪" FontSize="15" Foreground="#CCCCCC"/>
                    </Button>

                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Bottom bar -->
        <Border DockPanel.Dock="Bottom"
                Background="#252526"
                BorderBrush="#3C3C3C" BorderThickness="0,1,0,0"
                Height="28">
            <DockPanel Margin="4,0">

                <!-- Reset View -->
                <Button Style="{StaticResource StatusButtonStyle}"
                        DockPanel.Dock="Left"
                        Content="⌂  Reset View"
                        Click="ResetViewBtn_Click"/>

                <!-- Zoom Label -->
                <TextBlock x:Name="ZoomLabel"
                           DockPanel.Dock="Right"
                           Text="100%"
                           Foreground="#888" FontSize="11"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>

            </DockPanel>
        </Border>

        <!-- Canvas viewport -->
        <Grid x:Name="CanvasViewport"
              Background="#1A1A1A"
              ClipToBounds="True"
              MouseWheel="Viewport_MouseWheel"
              MouseDown="Viewport_MouseDown"
              MouseMove="Viewport_MouseMove"
              MouseUp="Viewport_MouseUp">

            <Canvas x:Name="EditorCanvas"
                    Width="40000000" Height="30000000"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Focusable ="True"
                    MouseMove="Canvas_MouseMove"
                    MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                    MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                    ContextMenuOpening="Canvas_ContextMenuOpening">

                <!-- Node Canvas Context Menu -->
                <Canvas.ContextMenu>
                    <ContextMenu x:Name="CanvasContextMenu">
                        <MenuItem Header="＋  Add Node"
                                  Style="{StaticResource ContextMenuItemStyle}"
                                  Click="ContextMenu_AddNode_Click"/>
                        <MenuItem Header="🁫  Copy Node(s)"
                                  Style="{StaticResource ContextMenuItemStyle}"
                                  Click="ContextMenu_CopyNode_Click"
                                  IsEnabled="{Binding IsAnyNodeSelected}"/>
                        <MenuItem Header="✐  Paste Node(s)"
                                  Style="{StaticResource ContextMenuItemStyle}"
                                  Click="ContextMenu_PasteNode_Click"
                                  IsEnabled="{Binding CanPaste}"/>
                        <MenuItem Header="✕  Delete Selected"
                                Style="{StaticResource ContextMenuItemStyle}"
                                Click="ContextMenu_DeleteSelected_Click"
                                IsEnabled="{Binding IsAnyNodeSelected}"/>

                    </ContextMenu>
                </Canvas.ContextMenu>

                <Canvas.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="CanvasScale" ScaleX="1" ScaleY="1"/>
                        <TranslateTransform x:Name="CanvasPan" X="0" Y="0"/>
                    </TransformGroup>
                </Canvas.RenderTransform>

                <Canvas.Background>
                    <DrawingBrush TileMode="Tile"
                                  Viewport="0,0,32,32" ViewportUnits="Absolute">
                        <DrawingBrush.Drawing>
                            <DrawingGroup>
                                <GeometryDrawing Brush="#1A1A1A">
                                    <GeometryDrawing.Geometry>
                                        <RectangleGeometry Rect="0,0,32,32"/>
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                                <GeometryDrawing Brush="#333333">
                                    <GeometryDrawing.Geometry>
                                        <EllipseGeometry Center="0,0" RadiusX="1" RadiusY="1"/>
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                            </DrawingGroup>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </Canvas.Background>

                <!--  Connection wires  -->
                <ItemsControl x:Name="ConnectionsControl"
                              ItemsSource="{Binding Connections}"
                              Panel.ZIndex="1">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas IsItemsHost="True"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="0"/>
                            <Setter Property="Canvas.Top"  Value="0"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:DialogueConnectionViewModel}">
                            <Path Data="{Binding Geometry}"
                                  Stroke="#CCCCCC" StrokeThickness="2.5"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Cursor="Hand" ToolTip="Left-click to delete"
                                  MouseLeftButtonDown="Wire_LeftClick"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!--  Preview wire  -->
                <Path x:Name="PreviewWire"
                      Stroke="Yellow" StrokeThickness="2"
                      StrokeDashArray="5,5"
                      Panel.ZIndex="5"
                      Visibility="Collapsed"/>

                <!--  Nodes  -->
                <ItemsControl x:Name="NodesControl"
                              ItemsSource="{Binding Nodes}"
                              Panel.ZIndex="10">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas IsItemsHost="True"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding X}"/>
                            <Setter Property="Canvas.Top"  Value="{Binding Y}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:DialogueNodeViewModel}">
                            <userControls:DialogueNodeControl
                                DataContext="{Binding}"
                                UndoRedoService ="{Binding DataContext.History, RelativeSource={RelativeSource AncestorType=Window}}"
                                OutConnectorClicked="NodeCtrl_OutConnectorClicked"
                                InConnectorClicked="NodeCtrl_InConnectorClicked"
                                DragHandleMouseDown="NodeCtrl_DragHandleMouseDown"
                                MouseLeftButtonDown="NodeCtrl_MouseLeftButtonDown"
                                SizeChanged="NodeCtrl_SizeChanged"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!--  Box-select  -->
                <Rectangle x:Name="SelectionRect"
                           Panel.ZIndex="20"
                           Visibility="Collapsed"
                           IsHitTestVisible="False"
                           StrokeThickness="1.5"
                           StrokeDashArray="4,3">
                    <Rectangle.Stroke>
                        <SolidColorBrush Color="#4FC3F7"/>
                    </Rectangle.Stroke>
                    <Rectangle.Fill>
                        <SolidColorBrush Color="#4FC3F7" Opacity="0.08"/>
                    </Rectangle.Fill>
                </Rectangle>
            </Canvas>
        </Grid>
    </DockPanel>
</Window>
